{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "rewrites": [
    { "source": "/api/:path*", "destination": "http://3.7.19.25:8080/api/:path*" },
    { "source": "/((?!dashboard|downloads|about-us|contact-us|privacy-policy|terms-conditions|refund-cancellation-policy).*)", "destination": "/index.html" }
  ]
}
